{
  "bgp_as": "65000",
  "default_node_types": [
    {
      "node_type": "spine",
      "match_hostnames": [
        ".*SPINE.*"
      ]
    },
    {
      "node_type": "l2leaf",
      "match_hostnames": [
        ".*L2LEAF.*"
      ]
    },
    {
      "node_type": "l3leaf",
      "match_hostnames": [
        ".*LEAF.*"
      ]
    }
  ],
  "eos_designs_documentation": {
    "enable": false
  },
  "fabric_name": "EOS_DESIGNS_UNIT_TESTS",
  "network_ports": [
    {
      "switches": [
        "UPLINK_P2P_VRFS_TESTS_L2LEAF1"
      ],
      "switch_ports": [
        "Ethernet10"
      ],
      "vlans": "66"
    }
  ],
  "node_type_keys": [
    {
      "key": "spine",
      "type": "spine",
      "default_evpn_role": "server",
      "default_ptp_priority1": 20,
      "network_services": {
        "l3": true
      }
    },
    {
      "key": "l3leaf",
      "type": "l3leaf",
      "connected_endpoints": true,
      "default_evpn_role": "client",
      "default_ptp_priority1": 30,
      "mlag_support": true,
      "network_services": {
        "l2": true,
        "l3": true
      },
      "vtep": true,
      "cv_tags_topology_type": "leaf"
    },
    {
      "key": "l2leaf",
      "type": "l2leaf",
      "connected_endpoints": true,
      "mlag_support": true,
      "network_services": {
        "l2": true
      },
      "underlay_router": false,
      "uplink_type": "port-channel",
      "cv_tags_topology_type": "leaf"
    }
  ],
  "overlay_routing_protocol": "none",
  "_dynamic_keys": {
    "connected_endpoints": [],
    "custom_node_types": [],
    "network_services": [
      {
        "key": "tenants",
        "network_services_keys_name": [
          {
            "name": "TenantA",
            "vrfs": [
              {
                "name": "default",
                "vrf_id": 1
              },
              {
                "name": "PROD",
                "vrf_id": 42
              },
              {
                "name": "IT",
                "vrf_id": 100
              }
            ]
          },
          {
            "name": "TenantB",
            "vrfs": [
              {
                "name": "PROD",
                "vrf_id": 42
              }
            ]
          },
          {
            "name": "TenantC",
            "mac_vrf_vni_base": 10000,
            "vrfs": [
              {
                "name": "ONLY-ON-L2LEAF",
                "vrf_id": 66,
                "svis": [
                  {
                    "id": 66,
                    "name": "TEST-L2VLAN-ATTRACTION",
                    "tags": [
                      "not-on-spine-2"
                    ],
                    "enabled": true,
                    "ip_address_virtual": "172.16.0.1/24"
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
    "node_types": [
      {
        "key": "spine",
        "node_type_keys_key": {
          "defaults": {
            "platform": "vEOS-LAB",
            "loopback_ipv4_pool": "192.168.42.0/24"
          },
          "nodes": [
            {
              "name": "UPLINK_P2P_VRFS_TESTS_SPINE1",
              "id": 1,
              "filter": {
                "tags": [
                  "not-on-spine-2"
                ],
                "always_include_vrfs_in_tenants": [
                  "TenantB",
                  "TenantC"
                ]
              }
            },
            {
              "name": "UPLINK_P2P_VRFS_TESTS_SPINE2",
              "id": 2,
              "filter": {
                "tags": [
                  "none"
                ],
                "always_include_vrfs_in_tenants": [
                  "TenantA"
                ]
              }
            }
          ]
        }
      },
      {
        "key": "l3leaf",
        "node_type_keys_key": {
          "defaults": {
            "platform": "vEOS-LAB",
            "uplink_type": "p2p-vrfs",
            "uplink_ipv4_pool": "10.42.42.0/24",
            "uplink_interfaces": [
              "Ethernet1",
              "Ethernet2"
            ],
            "uplink_switches": [
              "UPLINK_P2P_VRFS_TESTS_SPINE1",
              "UPLINK_P2P_VRFS_TESTS_SPINE2"
            ],
            "uplink_macsec": {
              "profile": "TEST"
            },
            "loopback_ipv4_pool": "192.168.42.0/24",
            "vtep_loopback_ipv4_pool": "172.16.0.0/24",
            "filter": {
              "always_include_vrfs_in_tenants": [
                "TenantA",
                "TenantB"
              ]
            },
            "virtual_router_mac_address": "cafe:cafe:cafe"
          },
          "nodes": [
            {
              "name": "UPLINK_P2P_VRFS_TESTS_LEAF1",
              "id": 3,
              "uplink_switch_interfaces": [
                "Ethernet1",
                "Ethernet2"
              ]
            }
          ]
        }
      },
      {
        "key": "l2leaf",
        "node_type_keys_key": {
          "defaults": {
            "platform": "vEOS-LAB",
            "uplink_interfaces": [
              "Ethernet1",
              "Ethernet2"
            ],
            "uplink_switches": [
              "UPLINK_P2P_VRFS_TESTS_LEAF1",
              "UPLINK_P2P_VRFS_TESTS_LEAF1"
            ]
          },
          "nodes": [
            {
              "name": "UPLINK_P2P_VRFS_TESTS_L2LEAF1",
              "id": 4,
              "uplink_switch_interfaces": [
                "Ethernet51",
                "Ethernet52"
              ],
              "filter": {
                "tags": [
                  "not-on-spine-2"
                ]
              }
            }
          ]
        }
      }
    ]
  }
}