  "fabric_name": "EOS_DESIGNS_UNIT_TESTS",
  "ipv4_acls": [
    {
      "name": "TEST-IPV4-ACL-WITH-IP-FIELDS-IN",
      "entries": [
        {
          "source": "any",
          "destination": "interface_ip",
          "sequence": 15,
          "action": "deny",
          "protocol": "ip"
        },
        {
          "source": "peer_ip",
          "destination": "interface_ip",
          "action": "permit",
          "protocol": "ip"
        }
      ]
    },
    {
      "name": "TEST-IPV4-ACL-WITH-IP-FIELDS-OUT",
      "entries": [
        {
          "remark": "Some remark will not require source and destination fields."
        },
        {
          "source": "interface_ip",
          "destination": "any",
          "action": "permit",
          "protocol": "ip"
        }
      ]
    },
    {
      "name": "TEST-IPV4-ACL-WITH-NO-FIELDS-IN",
      "entries": [
        {
          "source": "172.18.18.18",
          "destination": "any",
          "action": "permit",
          "protocol": "ip"
        }
      ]
    },
    {
      "name": "TEST-IPV4-ACL-WITH-NO-FIELDS-OUT",
      "entries": [
        {
          "source": "172.18.18.18",
          "destination": "any",
          "action": "permit",
          "protocol": "ip"
        }
      ]
    }
  ],
