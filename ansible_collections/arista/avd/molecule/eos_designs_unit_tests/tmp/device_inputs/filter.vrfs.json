{
  "eos_designs_documentation": {
    "enable": false
  },
  "fabric_name": "EOS_DESIGNS_UNIT_TESTS",
  "type": "l3leaf",
  "_custom_structured_configurations": [],
  "_dynamic_keys": {
    "connected_endpoints": [],
    "custom_node_types": [],
    "network_services": [
      {
        "key": "tenants",
        "network_services_keys_name": [
          {
            "name": "TENANT1",
            "vrfs": [
              {
                "name": "VRF1",
                "description": "This VRF would have been configured because it is attracted by Loopback, but it is prevented by filter.deny_vrfs",
                "loopbacks": [
                  {
                    "node": "filter.vrfs",
                    "loopback": 1,
                    "ip_address": "192.168.1.1/32"
                  }
                ]
              },
              {
                "name": "VRF2",
                "description": "This VRF is attracted by Loopback and will be configured because it is permitted by filter.allow_vrfs",
                "loopbacks": [
                  {
                    "node": "filter.vrfs",
                    "loopback": 2,
                    "ip_address": "192.168.1.1/32"
                  }
                ],
                "bgp": {
                  "enabled": false
                }
              },
              {
                "name": "VRF3",
                "description": "This VRF would have been configured because it is attracted by Loopback, but it is prevented because it is not permitted by filter.allow_vrfs",
                "loopbacks": [
                  {
                    "node": "filter.vrfs",
                    "loopback": 3,
                    "ip_address": "192.168.1.1/32"
                  }
                ]
              }
            ]
          },
          {
            "name": "TENANT2",
            "vrfs": [
              {
                "name": "VRF4",
                "description": "This VRF would have been configured because of always_include_vrfs_in_tenants, but it is prevented by filter.deny_vrfs"
              },
              {
                "name": "VRF5",
                "description": "This VRF will be configured because of always_include_vrfs_in_tenants and it is permitted by filter.allow_vrfs",
                "bgp": {
                  "enabled": false
                }
              },
              {
                "name": "VRF6",
                "description": "This VRF will not be configured because it is not permitted by filter.allow_vrfs"
              }
            ]
          }
        ]
      }
    ],
    "node_types": [
      {
        "key": "l3leaf",
        "node_type_keys_key": {
          "nodes": [
            {
              "name": "filter.vrfs",
              "id": 1,
              "loopback_ipv4_pool": "10.0.0.0/24",
              "vtep": false,
              "bgp_as": "65001",
              "filter": {
                "allow_vrfs": [
                  "VRF1",
                  "VRF2",
                  "VRF4",
                  "VRF5"
                ],
                "deny_vrfs": [
                  "VRF1",
                  "VRF4"
                ],
                "always_include_vrfs_in_tenants": [
                  "TENANT2"
                ]
              }
            }
          ]
        }
      }
    ]
  }
}